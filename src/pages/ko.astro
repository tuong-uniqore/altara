---
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="ALTARA RESIDENCES - 럭셔리 라이프스타일의 정점" 
    description="꾸이년 중심부의 프리미엄 영구 소유권 해변 레지던스."
    lang="ko"
>
	<main class="w-full bg-[#FAF9F6] text-[#2C2825] overflow-hidden selection:bg-[#9B6B43] selection:text-white">
        <!-- Navigation Bar -->
        <nav class="fixed top-0 w-full z-[80] px-6 lg:px-16 py-6 flex justify-between items-center text-white transition-all duration-[400ms] border-b border-transparent" id="navbar">
            <div class="flex flex-col hover:scale-105 transition-transform cursor-pointer">
                <div class="font-serif text-2xl lg:text-3xl tracking-[0.2em] font-medium uppercase text-center lg:text-left">
                    Altara
                </div>
                <div class="text-[8px] lg:text-[9px] font-bold tracking-[0.25em] uppercase text-[#D4AF37] mt-1 lg:mt-0.5 text-center lg:text-left">
                    Premium Residences
                </div>
            </div>
            
            <!-- Desktop Menu -->
            <div class="hidden md:flex gap-10 text-[11px] font-semibold tracking-[0.2em] uppercase items-center">
                <a href="#tong-quan" class="hover:text-[#D4AF37] transition-colors relative group">
                    개요
                    <span class="absolute -bottom-2 left-0 w-0 h-[1px] bg-[#D4AF37] transition-all duration-300 group-hover:w-full"></span>
                </a>
                <a href="#phoi-canh" class="hover:text-[#D4AF37] transition-colors relative group">
                    건축
                    <span class="absolute -bottom-2 left-0 w-0 h-[1px] bg-[#D4AF37] transition-all duration-300 group-hover:w-full"></span>
                </a>
                <a href="#vi-tri" class="hover:text-[#D4AF37] transition-colors relative group">
                    위치
                    <span class="absolute -bottom-2 left-0 w-0 h-[1px] bg-[#D4AF37] transition-all duration-300 group-hover:w-full"></span>
                </a>
                <a href="#bang-gia" class="hover:text-[#D4AF37] transition-colors relative group">
                    가격
                    <span class="absolute -bottom-2 left-0 w-0 h-[1px] bg-[#D4AF37] transition-all duration-300 group-hover:w-full"></span>
                </a>
            </div>

            <!-- Right Actions -->
            <div class="flex items-center gap-4 lg:gap-6">
                <!-- Language Dropdown -->
                <div class="group relative flex items-center justify-center bg-white/10 border border-white/20 backdrop-blur-md px-3 md:px-4 py-1.5 md:py-2 rounded-full text-[9px] md:text-[10px] tracking-widest cursor-pointer z-50">
                    <div class="flex items-center gap-2">
                        <img src="https://flagcdn.com/w20/kr.png" alt="KR" class="w-3.5 md:w-4 h-auto rounded-sm">
                        <span class="font-bold text-[#D4AF37]">KR</span>
                        <svg class="w-3 h-3 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </div>
                    <!-- Dropdown -->
                    <div class="absolute top-[calc(100%+8px)] right-0 bg-[#1A1817]/90 backdrop-blur-lg border border-white/20 rounded-xl overflow-hidden opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-300 w-28 flex flex-col shadow-2xl">
                        <a href="/" class="flex items-center gap-3 px-4 py-3 hover:bg-white/10 transition-colors text-white/50 hover:text-white border-b border-white/10">
                            <img src="https://flagcdn.com/w20/vn.png" alt="VI" class="w-4 h-auto rounded-sm"> VI
                        </a>
                        <a href="/en" class="flex items-center gap-3 px-4 py-3 hover:bg-white/10 transition-colors text-white/50 hover:text-white border-b border-white/10">
                            <img src="https://flagcdn.com/w20/gb.png" alt="EN" class="w-4 h-auto rounded-sm"> EN
                        </a>
                        <a href="/ko" class="flex items-center gap-3 px-4 py-3 bg-[#D4AF37]/20 transition-colors text-white/90">
                            <img src="https://flagcdn.com/w20/kr.png" alt="KR" class="w-4 h-auto rounded-sm"> KR
                        </a>
                    </div>
                </div>
                <!-- Hamburger Menu Button -->
                <button id="mobileMenuBtn" class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-[5px] focus:outline-none group z-50">
                    <span class="w-6 h-[1.5px] bg-white transition-all duration-300 origin-center group-[.active]:rotate-45 group-[.active]:translate-y-[6.5px]"></span>
                    <span class="w-6 h-[1.5px] bg-white transition-all duration-300 group-[.active]:opacity-0"></span>
                    <span class="w-6 h-[1.5px] bg-white transition-all duration-300 origin-center group-[.active]:-rotate-45 group-[.active]:-translate-y-[6.5px]"></span>
                </button>
                <button class="hidden md:block border border-white/50 px-6 py-3 text-[11px] font-semibold tracking-[0.15em] uppercase hover:bg-white hover:text-black transition-all duration-500 backdrop-blur-sm">
                    등록
                </button>
            </div>
        </nav>

        <!-- Mobile Menu Overlay -->
        <div id="mobileMenu" class="fixed inset-0 bg-[#1A1817] z-[55] flex flex-col justify-center items-center opacity-0 pointer-events-none transition-all duration-500 min-h-[100svh]">
            <div class="flex flex-col gap-10 text-center text-sm font-semibold tracking-[0.2em] uppercase">
                <a href="#tong-quan" class="text-white hover:text-[#D4AF37] transition-colors mobile-link">개요</a>
                <a href="#phoi-canh" class="text-white hover:text-[#D4AF37] transition-colors mobile-link">건축</a>
                <a href="#vi-tri" class="text-white hover:text-[#D4AF37] transition-colors mobile-link">위치</a>
                <a href="#bang-gia" class="text-white hover:text-[#D4AF37] transition-colors mobile-link">가격</a>
                <button class="mt-8 border border-[#D4AF37] text-[#D4AF37] px-8 py-4 text-[11px] tracking-widest uppercase hover:bg-[#D4AF37] hover:text-[#1A1817] transition-colors">지금 등록</button>
            </div>
        </div>

        <!-- Hero Section (Variant: Split Screen) -->
        <section id="tong-quan" class="relative w-full min-h-[100svh] flex flex-col lg:flex-row bg-[#1A1817] overflow-hidden pt-0">
            <!-- Left Text Column -->
            <div class="w-full lg:w-1/2 lg:flex-1 flex flex-col justify-center px-8 lg:px-24 py-16 lg:py-0 relative z-10 order-2 lg:order-1">
                <p class="text-[#D4AF37] tracking-[0.4em] text-[10px] font-bold uppercase mb-8 flex items-center gap-4">
                    <span class="w-8 h-[2px] bg-[#D4AF37]"></span> 새로운 기준
                </p>
                <h1 class="font-sans text-white text-5xl md:text-7xl lg:text-[5.5rem] leading-[1.05] font-light tracking-tight mb-8">
                    우아함의 <br />
                    <span class="font-serif italic text-[#8B5A2B]">기원</span>
                </h1>
                <p class="text-white/40 text-sm font-light leading-relaxed max-w-md mb-12">
                    76 쩐흥다오, 꾸이년 해안 도시. 5성급 편의시설과 제한된 프라이빗 주거 공간의 완벽한 조화.
                </p>
                <div class="flex items-center gap-8">
                    <button class="bg-white text-[#1A1817] px-8 py-4 text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#D4AF37] transition-colors">
                        방문하기
                    </button>
                    <a href="#phoi-canh" class="text-white/60 text-xs tracking-widest uppercase hover:text-white flex items-center gap-2 group transition-colors">
                        둘러보기 <span class="group-hover:translate-x-2 transition-transform">→</span>
                    </a>
                </div>
            </div>
            
            <!-- Right Image Column (Slider) -->
            <div class="w-full lg:w-1/2 lg:flex-1 relative min-h-[55vh] lg:min-h-0 lg:h-[100svh] lg:order-2 order-1 overflow-hidden shrink-0">
                <img src="/photos/3.jpg" alt="Altara Slide 1" class="hero-slide absolute inset-0 w-full h-full object-cover object-center transform scale-105 transition-opacity duration-[2000ms] opacity-100" />
                <img src="/photos/4.jpg" alt="Altara Slide 2" class="hero-slide absolute inset-0 w-full h-full object-cover object-center transform scale-105 transition-opacity duration-[2000ms] opacity-0" />
                <img src="/photos/7.jpg" alt="Altara Slide 3" class="hero-slide absolute inset-0 w-full h-full object-cover object-center transform scale-105 transition-opacity duration-[2000ms] opacity-0" />
                <div class="absolute inset-0 bg-[#A68A64] mix-blend-multiply opacity-20 pointer-events-none"></div>
                <!-- Decor Lines -->
                <div class="absolute left-0 top-0 h-full w-[1px] bg-white/20 hidden lg:block"></div>
                <!-- Box Stats overlay -->
                <div class="absolute bottom-12 right-12 bg-white/10 backdrop-blur-xl border border-white/20 p-6 hidden md:block group hover:bg-white/20 transition-colors cursor-default">
                    <p class="font-serif text-3xl text-white mb-1 group-hover:scale-110 origin-left transition-transform">100%</p>
                    <p class="text-[9px] uppercase tracking-[0.2em] text-[#D4AF37]">오션뷰</p>
                </div>
            </div>
        </section>

        <!-- 예술적 공간 Section -->
        <section id="phoi-canh" class="py-32 lg:py-48 px-6 lg:px-16 bg-white relative">
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-stretch">
                    <!-- Text Block -->
                    <div class="flex flex-col justify-center">
                        <p class="text-[#D4AF37] tracking-[0.4em] text-[10px] font-bold uppercase mb-8 flex items-center gap-4">
                            <span class="w-8 h-[2px] bg-[#D4AF37]"></span> 예술적 공간
                        </p>
                        <h2 class="font-sans text-5xl lg:text-[4rem] text-[#1A1817] leading-[1.1] tracking-tight mb-10 font-light">
                            미니멀리스트 <br />
                            <span class="font-serif italic text-[#D4AF37] pr-2">철학</span>
                        </h2>
                        <p class="text-[#1A1817]/60 leading-relaxed font-light mb-16 text-sm lg:text-base max-w-md">
                            불필요한 디테일을 배제하고 근본적인 비율, 자연 채광 그리고 최고급 자재를 돋보이게 하여 평온한 주거 공간의 교향곡을 완성합니다.
                        </p>
                        <div class="flex gap-16 border-t border-[#1A1817]/10 pt-8">
                            <div>
                                <h4 class="font-serif text-4xl text-[#1A1817] mb-2">479</h4>
                                <p class="text-[9px] uppercase tracking-[0.2em] text-[#1A1817]/40 font-bold">한정판 특별 세대</p>
                            </div>
                            <div>
                                <h4 class="font-serif text-4xl text-[#1A1817] mb-2">100<span class="text-xl">%</span></h4>
                                <p class="text-[9px] uppercase tracking-[0.2em] text-[#1A1817]/40 font-bold">Direct 오션뷰</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Premium Collage Block -->
                    <div class="relative w-full h-[60vh] lg:h-auto lg:aspect-[4/5] grid grid-cols-2 grid-rows-2 gap-2 lg:gap-4 group">
                        <!-- Main Image -->
                        <div class="col-span-2 row-span-1 border border-[#D4AF37]/20 relative overflow-hidden bg-black">
                            <img src="/photos/5.jpg" alt="Luxury Living" class="w-full h-full object-cover transform scale-105 hover:scale-110 transition-transform duration-1000 ease-out opacity-90 hover:opacity-100" />
                            <div class="absolute bottom-6 left-6 text-white font-serif italic text-xl drop-shadow-md">생활 공간.</div>
                        </div>
                        <!-- Bottom Images -->
                        <div class="col-span-1 row-span-1 border border-[#D4AF37]/20 relative overflow-hidden bg-black">
                            <img src="/photos/7.jpg" alt="Elegant Details" class="w-full h-full object-cover transform scale-105 hover:scale-110 transition-transform duration-1000 ease-out opacity-90 hover:opacity-100" />
                        </div>
                        <div class="col-span-1 row-span-1 border border-[#D4AF37]/20 relative overflow-hidden bg-black">
                            <img src="/photos/8.jpg" alt="High-end Finish" class="w-full h-full object-cover transform scale-105 hover:scale-110 transition-transform duration-1000 ease-out opacity-90 hover:opacity-100" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 위치 Section -->
        <section id="vi-tri" class="py-32 lg:py-48 px-6 lg:px-16 bg-[#111] text-white overflow-hidden relative">
            <!-- Background element -->
            <div class="absolute top-0 right-0 w-1/3 h-full bg-[#1A1817] -skew-x-12 translate-x-32 hidden lg:block"></div>

            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-20 items-center relative z-10">
                <div class="lg:col-span-5 order-2 lg:order-1 relative group">
                    <div class="absolute inset-0 border border-[#D4AF37]/30 translate-x-4 translate-y-4 transition-transform duration-500 group-hover:translate-x-6 group-hover:translate-y-6"></div>
                    <img src="/photos/6.jpg" alt="위치 Map" class="relative z-10 w-full aspect-[4/5] object-cover grayscale opacity-70 mix-blend-luminosity hover:opacity-100 hover:grayscale-0 transition-all duration-700" />
                    <div class="absolute inset-0 z-20 flex items-center justify-center pointer-events-none">
                        <div class="bg-black/40 backdrop-blur-md px-8 py-6 border-l-[3px] border-[#D4AF37]">
                            <span class="font-sans text-xl md:text-2xl tracking-[0.2em] font-light uppercase">76 Tran Hung Dao</span>
                        </div>
                    </div>
                </div>
                
                <div class="lg:col-span-1 hidden lg:block border-none"></div>

                <div class="lg:col-span-6 order-1 lg:order-2">
                    <p class="text-[#D4AF37] tracking-[0.4em] text-[10px] font-bold uppercase mb-8 flex items-center gap-4">
                        <span class="w-8 h-[2px] bg-[#D4AF37]"></span> Prime 위치
                    </p>
                    <h2 class="font-sans text-4xl lg:text-[4rem] leading-[1.1] font-light tracking-tight mb-16">
                        엘리트들의 <br/><span class="font-serif italic text-white/50">교차로</span>
                    </h2>
                    
                    <div class="space-y-10">
                        <div class="group flex gap-8 items-start hover:-translate-y-1 transition-transform cursor-default">
                            <span class="font-sans text-4xl text-[#D4AF37] opacity-60 font-light group-hover:opacity-100 transition-opacity">01</span>
                            <div>
                                <h4 class="text-sm font-bold uppercase tracking-[0.1em] mb-2">파도까지 단 1분</h4>
                                <p class="text-white/40 font-light text-sm leading-relaxed max-w-sm">문 밖을 나서면 끝없이 펼쳐진 푸른 지평선, 파도 소리, 부드러운 모래사장을 바로 만날 수 있습니다.</p>
                            </div>
                        </div>
                        <div class="w-full h-[1px] bg-white/10 mix-blend-overlay"></div>
                        <div class="group flex gap-8 items-start hover:-translate-y-1 transition-transform cursor-default">
                            <span class="font-sans text-4xl text-[#D4AF37] opacity-60 font-light group-hover:opacity-100 transition-opacity">03</span>
                            <div>
                                <h4 class="text-sm font-bold uppercase tracking-[0.1em] mb-2">시청 광장까지 3분</h4>
                                <p class="text-white/40 font-light text-sm leading-relaxed max-w-sm">화려한 도 광장에서 펼쳐지는 문화, 주요 행사 및 경이로운 예술 축제의 중심지입니다.</p>
                            </div>
                        </div>
                        <div class="w-full h-[1px] bg-white/10 mix-blend-overlay"></div>
                        <div class="group flex gap-8 items-start hover:-translate-y-1 transition-transform cursor-default">
                            <span class="font-sans text-4xl text-[#D4AF37] opacity-60 font-light group-hover:opacity-100 transition-opacity">05</span>
                            <div>
                                <h4 class="text-sm font-bold uppercase tracking-[0.1em] mb-2">5분 거리의 편의성</h4>
                                <p class="text-white/40 font-light text-sm leading-relaxed max-w-sm">국제 표준 병원 및 명문 교육 시스템과의 완벽하고 신속한 연결.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 가격 Section -->
        <section id="bang-gia" class="py-32 lg:py-48 px-6 lg:px-16 bg-[#F9F9F9]">
            <div class="max-w-7xl mx-auto">
                <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-20 lg:mb-32 gap-10">
                    <div>
                        <p class="text-[#D4AF37] tracking-[0.4em] text-[10px] font-bold uppercase mb-6 flex items-center gap-4">
                            <span class="w-8 h-[2px] bg-[#D4AF37]"></span> 지속 가능한 투자
                        </p>
                        <h2 class="font-sans text-4xl lg:text-[4rem] text-[#1A1817] leading-none font-light tracking-tight">가치 있는 걸작</h2>
                    </div>
                    <p class="font-serif text-[#1A1817]/40 text-2xl lg:text-3xl italic tracking-wide">가치 상승</p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 border border-[#1A1817]/10 bg-white">
                    <!-- Unit: 1BR -->
                    <div class="p-10 lg:p-14 border-b lg:border-b-0 lg:border-r border-[#1A1817]/10 hover:bg-[#FAF9F6] transition-colors group flex flex-col">
                        <p class="text-[#D4AF37] text-[9px] uppercase tracking-[0.2em] font-bold mb-8">영구 소유권</p>
                        <h3 class="font-sans text-2xl text-[#1A1817] font-light mb-10 uppercase tracking-widest">1베드룸</h3>
                        
                        <div class="mb-12">
                            <span class="text-xs uppercase tracking-[0.2em] text-[#1A1817]/40 block mb-2">시작가:</span>
                            <div class="font-serif text-5xl text-[#1A1817]">1.8 <span class="text-xl font-sans font-light">십억 (VND)</span></div>
                        </div>

                        <ul class="space-y-5 text-xs tracking-[0.1em] text-[#1A1817]/60 uppercase mb-16 flex-1">
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> 크기: 45m²</li>
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> 개방형 미니멀리스트 디자인</li>
                            <li class="flex items-center gap-4 opacity-40"><span class="w-[4px] h-[4px] bg-gray-400"></span> 막힘없는 전망</li>
                        </ul>

                        <button class="w-full border border-[#1A1817]/20 text-[#1A1817] py-5 text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#1A1817] hover:text-white transition-all">
                            1차 견적 받기
                        </button>
                    </div>

                    <!-- Unit: 2BR (Featured) -->
                    <div class="p-10 lg:p-14 bg-[#1A1817] text-white hover:bg-[#111] transition-colors border-b lg:border-b-0 lg:border-r border-[#1A1817] relative flex flex-col group transform lg:scale-105 lg:-mt-4 lg:mb-4 shadow-2xl z-10">
                        <div class="absolute top-0 left-0 w-full h-[2px] bg-[#D4AF37]"></div>
                        <p class="text-[#D4AF37] text-[9px] uppercase tracking-[0.2em] font-bold mb-8 flex justify-between items-center">
                            엘리트 컬렉션
                            <span class="px-2 py-1 bg-[#D4AF37]/20 text-[#D4AF37] border border-[#D4AF37]/50 tracking-widest">HOT</span>
                        </p>
                        <h3 class="font-sans text-2xl text-white font-light mb-10 uppercase tracking-widest">2베드룸</h3>
                        
                        <div class="mb-12">
                            <span class="text-xs uppercase tracking-[0.2em] text-white/40 block mb-2">시작가:</span>
                            <div class="font-serif text-5xl text-[#D4AF37]">2.5 <span class="text-xl font-sans font-light text-white">십억 (VND)</span></div>
                        </div>

                        <ul class="space-y-5 text-xs tracking-[0.1em] text-white/70 uppercase mb-16 flex-1">
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> 크기: 75m²</li>
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> 초광폭 발코니</li>
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> Panoramic 오션뷰</li>
                            <li class="flex items-center gap-4 text-[#D4AF37]"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> 연 8% 수익 보장</li>
                        </ul>

                        <button class="w-full bg-[#D4AF37] text-[#1A1817] py-5 text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-white transition-all">
                            단독 상담 신청
                        </button>
                    </div>

                    <!-- Unit: Penthouse -->
                    <div class="p-10 lg:p-14 hover:bg-[#FAF9F6] transition-colors group flex flex-col">
                        <p class="text-[#1A1817]/40 text-[9px] uppercase tracking-[0.2em] font-bold mb-8">리미티드 에디션</p>
                        <h3 class="font-sans text-2xl text-[#1A1817] font-light mb-10 uppercase tracking-widest">Penthouse</h3>
                        
                        <div class="mb-12">
                            <span class="text-xs uppercase tracking-[0.2em] text-[#1A1817]/40 block mb-2">내부 할당 (비공개)</span>
                            <div class="font-serif text-3xl md:text-4xl text-[#1A1817] mt-3">직접 문의</div>
                        </div>

                        <ul class="space-y-5 text-xs tracking-[0.1em] text-[#1A1817]/60 uppercase mb-16 flex-1">
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> 면적 > 150m²</li>
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> VIP 특권 제공</li>
                            <li class="flex items-center gap-4"><span class="w-[4px] h-[4px] bg-[#D4AF37]"></span> 황실급 편의시설</li>
                        </ul>

