<script>
    document.addEventListener("astro:page-load", () => {
        // --- Mobile Menu Logic ---
        const mobileMenuBtn = document.getElementById("mobileMenuBtn");
        const mobileMenu = document.getElementById("mobileMenu");
        const mobileLinks = document.querySelectorAll(".mobile-link");

        if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener("click", () => {
                mobileMenuBtn.classList.toggle("active");
                if (mobileMenuBtn.classList.contains("active")) {
                    mobileMenu.classList.remove("opacity-0", "pointer-events-none");
                    mobileMenu.classList.add("opacity-100", "pointer-events-auto");
                    document.body.style.overflow = "hidden"; // Prevent scrolling
                } else {
                    mobileMenu.classList.add("opacity-0", "pointer-events-none");
                    mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
                    document.body.style.overflow = "auto";
                }
            });

            // Close menu when clicking a link
            mobileLinks.forEach(link => {
                link.addEventListener("click", () => {
                    mobileMenuBtn.classList.remove("active");
                    mobileMenu.classList.add("opacity-0", "pointer-events-none");
                    mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
                    document.body.style.overflow = "auto";
                });
            });
        }

        // --- Registration Modal Logic ---
        const registerModal = document.getElementById("registerModal");
        const modalPanel = registerModal?.querySelector(".modal-panel");
        const closeBtns = document.querySelectorAll(".close-modal, .modal-backdrop");
        
        // Auto-add open-register class to all CTA buttons
        const ctaButtons = document.querySelectorAll(
            '#navbar button:not(#mobileMenuBtn), #mobileMenu button, #tong-quan button, #bang-gia button'
        );
        ctaButtons.forEach(btn => btn.classList.add('open-register'));
        
        const openModalBtns = document.querySelectorAll(".open-register");

        if (registerModal && modalPanel) {
            const openModal = () => {
                registerModal.classList.remove("opacity-0", "pointer-events-none");
                setTimeout(() => {
                    modalPanel.classList.remove("scale-95", "opacity-0");
                    modalPanel.classList.add("scale-100", "opacity-100");
                }, 10);
                document.body.style.overflow = "hidden";
                
                // Auto-focus the first input field for better UX
                const firstInput = registerModal.querySelector('input[name="name"]');
                if (firstInput) {
                    setTimeout(() => {
                        firstInput.focus();
                    }, 400); // Wait for modal transition to finish
                }
                
                // If mobile menu is open, close it
                if (mobileMenuBtn && mobileMenuBtn.classList.contains("active")) {
                    mobileMenuBtn.click();
                }
            };

            const closeModal = (e) => {
                if(e) e.preventDefault();
                modalPanel.classList.remove("scale-100", "opacity-100");
                modalPanel.classList.add("scale-95", "opacity-0");
                setTimeout(() => {
                    registerModal.classList.add("opacity-0", "pointer-events-none");
                    document.body.style.overflow = "auto";
                }, 300);
            };

            openModalBtns.forEach(btn => btn.addEventListener("click", openModal));
            closeBtns.forEach(btn => btn.addEventListener("click", closeModal));
        }

        

        // --- Auto/Smart Popup (Exit Intent + Scroll + Time) ---
        const hasSeenPopup = sessionStorage.getItem('altara_popup_seen');
        
        if (!hasSeenPopup && registerModal && modalPanel) {
            let popupTriggered = false;

            const triggerAutoPopup = () => {
                if (popupTriggered) return;
                popupTriggered = true;
                sessionStorage.setItem('altara_popup_seen', 'true'); // Only show ONCE per session
                
                // Simulate click on open register
                registerModal.classList.remove("opacity-0", "pointer-events-none");
                setTimeout(() => {
                    modalPanel.classList.remove("scale-95", "opacity-0");
                    modalPanel.classList.add("scale-100", "opacity-100");
                }, 10);
                document.body.style.overflow = "hidden";
            };

            // Trigger 1: Time Dwell (45 seconds)
            setTimeout(triggerAutoPopup, 45000);

            // Trigger 2: Read Depth (Scrolled 60% of the page)
            const checkScrollDepth = () => {
                const scrollPercent = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
                if (scrollPercent > 0.6) {
                    triggerAutoPopup();
                    window.removeEventListener('scroll', checkScrollDepth);
                }
            };
            window.addEventListener('scroll', checkScrollDepth);

            // Trigger 3: Exit Intent (Mouse leaves top of window - Desktop)
            document.addEventListener("mouseleave", (e) => {
                if (e.clientY < 0) {
                    triggerAutoPopup();
                }
            });
        }

        // --- AJAX Form Submission Logic ---
        const vipForm = document.getElementById("vipRegisterForm");
        const successMsg = document.getElementById("successMessage");
        const submitBtn = document.getElementById("submitBtn");

        if (vipForm) {
            vipForm.addEventListener("submit", function(e) {
                e.preventDefault();
                const formData = new FormData(vipForm);
                const data = Object.fromEntries(formData.entries());
                
                submitBtn.innerHTML = "Đang gửi...";
                submitBtn.classList.add("opacity-50", "pointer-events-none");

                fetch("https://formsubmit.co/ajax/tuongnm@gmail.com", {
                    method: "POST",
                    headers: { 
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(data)
                })
                .then(response => response.json())
                .then(data => {
                    vipForm.classList.add("hidden");
                    successMsg.classList.remove("hidden");
                    successMsg.classList.add("flex");
                })
                .catch(error => {
                    console.log(error);
                    submitBtn.innerHTML = "Lỗi. Vui lòng thử lại!";
                    setTimeout(() => {
                        submitBtn.innerHTML = "Gửi Yêu Cầu";
                        submitBtn.classList.remove("opacity-50", "pointer-events-none");
                    }, 3000);
                });
            });
        }

        // --- Scroll Logic ---
        const scrollToTopBtn = document.getElementById("scrollToTopBtn");
        const navbar = document.getElementById("navbar");
        
        if (scrollToTopBtn) {
            window.addEventListener("scroll", () => {
                // Navbar scroll effect
                if (window.scrollY > 50) {
                    navbar?.classList.add("scrolled");
                } else {
                    navbar?.classList.remove("scrolled");
                }

                // Scroll to top button logic
                if (window.scrollY > 600) {
                    scrollToTopBtn.classList.remove("opacity-0", "pointer-events-none", "translate-y-4");
                    scrollToTopBtn.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
                } else {
                    scrollToTopBtn.classList.add("opacity-0", "pointer-events-none", "translate-y-4");
                    scrollToTopBtn.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
                }
            });

            scrollToTopBtn.addEventListener("click", () => {
                window.scrollTo({
                    top: 0,
                    behavior: "smooth"
                });
            });
        }

        // --- Smooth Scroll without Hash in URL ---
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                
                const targetId = this.getAttribute('href');
                if (targetId === '#') return;
                
                const targetElement = document.querySelector(targetId);
                
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop,
                        behavior: 'smooth'
                    });
                }
            });
        });

        // --- Modal Slider Logic ---
        const modalSlides = document.querySelectorAll('.modal-slide');
        if (modalSlides.length > 1) {
            let mSlide = 0;
            setInterval(() => {
                modalSlides[mSlide].classList.remove('opacity-90');
                modalSlides[mSlide].classList.add('opacity-0');
                mSlide = (mSlide + 1) % modalSlides.length;
                modalSlides[mSlide].classList.remove('opacity-0');
                modalSlides[mSlide].classList.add('opacity-90');
            }, 3000); // Crossfade every 3s
        }

        // --- Hero Slider Logic ---
        const sliderImgs = document.querySelectorAll('.hero-slide');
        if (sliderImgs.length > 1) {
            let currentSlide = 0;
            setInterval(() => {
                sliderImgs[currentSlide].classList.remove('opacity-100');
                sliderImgs[currentSlide].classList.add('opacity-0');
                
                currentSlide = (currentSlide + 1) % sliderImgs.length;
                
                sliderImgs[currentSlide].classList.remove('opacity-0');
                sliderImgs[currentSlide].classList.add('opacity-100');
            }, 4000); // Crossfade every 4s
        }
    });
</script>

